<!-- Dark theme color tokens (per docs/functional-design.md) -->
<ResourceDictionary
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <Color x:Key="BackgroundPrimaryColor">#1E1E1E</Color>
  <Color x:Key="BackgroundPanelColor">#252526</Color>
  <Color x:Key="BackgroundCanvasColor">#121212</Color>
  <Color x:Key="BorderSubtleColor">#3F3F3F</Color>
  <Color x:Key="TextPrimaryColor">#E8E8E8</Color>
  <Color x:Key="TextDisabledColor">#808080</Color>
  <Color x:Key="AccentColor">#4CC2FF</Color>

  <SolidColorBrush x:Key="BackgroundPrimaryBrush" Color="{StaticResource BackgroundPrimaryColor}" />
  <SolidColorBrush x:Key="BackgroundPanelBrush" Color="{StaticResource BackgroundPanelColor}" />
  <SolidColorBrush x:Key="BackgroundCanvasBrush" Color="{StaticResource BackgroundCanvasColor}" />
  <SolidColorBrush x:Key="BorderSubtleBrush" Color="{StaticResource BorderSubtleColor}" />
  <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}" />
  <SolidColorBrush x:Key="TextDisabledBrush" Color="{StaticResource TextDisabledColor}" />
  <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />

  <!-- Culling UI (flags, stars, color labels) -->
  <Color x:Key="FlagPickColor">#53B25C</Color>
  <Color x:Key="FlagRejectColor">#E5484D</Color>
  <Color x:Key="RatingStarColor">#E5C04B</Color>
  <Color x:Key="LabelRedColor">#E5484D</Color>
  <Color x:Key="LabelYellowColor">#E5C04B</Color>
  <Color x:Key="LabelGreenColor">#53B25C</Color>
  <Color x:Key="LabelBlueColor">#4C9CE5</Color>
  <Color x:Key="LabelPurpleColor">#A16BD8</Color>

  <SolidColorBrush x:Key="FlagPickBrush" Color="{StaticResource FlagPickColor}" />
  <SolidColorBrush x:Key="FlagRejectBrush" Color="{StaticResource FlagRejectColor}" />
  <SolidColorBrush x:Key="RatingStarBrush" Color="{StaticResource RatingStarColor}" />
  <SolidColorBrush x:Key="LabelRedBrush" Color="{StaticResource LabelRedColor}" />
  <SolidColorBrush x:Key="LabelYellowBrush" Color="{StaticResource LabelYellowColor}" />
  <SolidColorBrush x:Key="LabelGreenBrush" Color="{StaticResource LabelGreenColor}" />
  <SolidColorBrush x:Key="LabelBlueBrush" Color="{StaticResource LabelBlueColor}" />
  <SolidColorBrush x:Key="LabelPurpleBrush" Color="{StaticResource LabelPurpleColor}" />

</ResourceDictionary>
