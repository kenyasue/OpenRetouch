<Window
  x:Class="OpenRetouch.App.MainWindow"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <Grid x:Name="RootGrid"
        RequestedTheme="Dark"
        Background="{StaticResource BackgroundPrimaryBrush}">
    <Grid.RowDefinitions>
      <RowDefinition Height="48" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <!-- Top Bar -->
    <Border Grid.Row="0"
            Background="{StaticResource BackgroundPanelBrush}"
            BorderBrush="{StaticResource BorderSubtleBrush}"
            BorderThickness="0,0,0,1">
      <Grid>
        <StackPanel Orientation="Horizontal" Spacing="4" Margin="8,0" VerticalAlignment="Center">
          <TextBlock Text="Open Retouch"
                     FontWeight="SemiBold"
                     Foreground="{StaticResource TextPrimaryBrush}"
                     VerticalAlignment="Center"
                     Margin="4,0,16,0" />
          <Button Content="Import" Command="{x:Bind ViewModel.ImportFolderCommand}" />
          <Button Content="Library" Command="{x:Bind ViewModel.NavigateLibraryCommand}" Margin="12,0,0,0" />
          <Button Content="Edit" Command="{x:Bind ViewModel.NavigateEditCommand}" />
          <Button Content="Export" Command="{x:Bind ViewModel.NavigateExportCommand}" />
        </StackPanel>
        <StackPanel Orientation="Horizontal" Spacing="4" Margin="8,0" VerticalAlignment="Center"
                    HorizontalAlignment="Right">
          <Button Content="Settings" Command="{x:Bind ViewModel.NavigateSettingsCommand}" />
        </StackPanel>
      </Grid>
    </Border>

    <!-- Content -->
    <Frame x:Name="ContentFrame" Grid.Row="1" />

    <!-- Job Progress Bar -->
    <Border Grid.Row="2"
            Background="{StaticResource BackgroundPanelBrush}"
            BorderBrush="{StaticResource BorderSubtleBrush}"
            BorderThickness="0,1,0,0"
            Padding="12,4"
            Visibility="{x:Bind ViewModel.IsJobRunning, Mode=OneWay}">
      <StackPanel Orientation="Horizontal" Spacing="12">
        <ProgressBar Width="200"
                     VerticalAlignment="Center"
                     Value="{x:Bind ViewModel.JobProgressValue, Mode=OneWay}"
                     IsIndeterminate="{x:Bind ViewModel.IsJobIndeterminate, Mode=OneWay}"
                     Maximum="100" />
        <TextBlock Text="{x:Bind ViewModel.JobStatusText, Mode=OneWay}"
                   Foreground="{StaticResource TextPrimaryBrush}"
                   VerticalAlignment="Center"
                   FontSize="12" />
      </StackPanel>
    </Border>
  </Grid>
</Window>
