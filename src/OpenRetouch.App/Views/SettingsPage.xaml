<Page
  x:Class="OpenRetouch.App.Views.SettingsPage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:models="using:OpenRetouch.Core.Models"
  Background="{StaticResource BackgroundPrimaryBrush}">

  <ScrollViewer>
    <StackPanel MaxWidth="560"
                HorizontalAlignment="Left"
                Margin="32"
                Spacing="20">
      <TextBlock Text="Settings"
                 FontSize="28"
                 Foreground="{StaticResource TextPrimaryBrush}" />

      <StackPanel Spacing="8">
        <TextBlock Text="Cache Limit (GB)"
                   Foreground="{StaticResource TextPrimaryBrush}" />
        <NumberBox Value="{x:Bind ViewModel.CacheLimitGb, Mode=TwoWay}"
                   Minimum="1"
                   Maximum="500"
                   SpinButtonPlacementMode="Inline"
                   SmallChange="1"
                   HorizontalAlignment="Left"
                   Width="200" />
        <TextBlock Text="Maximum combined size of the thumbnail and preview caches"
                   FontSize="12"
                   Foreground="{StaticResource TextDisabledBrush}" />
      </StackPanel>

      <StackPanel Spacing="8">
        <TextBlock Text="Default Import Folder"
                   Foreground="{StaticResource TextPrimaryBrush}" />
        <StackPanel Orientation="Horizontal" Spacing="8">
          <TextBox Text="{x:Bind ViewModel.DefaultImportFolder, Mode=TwoWay}"
                   PlaceholderText="(not set)"
                   Width="340" />
          <Button Content="Browse..."
                  Command="{x:Bind ViewModel.BrowseDefaultImportFolderCommand}" />
          <Button Content="Clear"
                  Command="{x:Bind ViewModel.ClearDefaultImportFolderCommand}" />
        </StackPanel>
        <TextBlock Text="Destination used when &quot;Copy to default folder&quot; is selected while importing from an SD card or similar"
                   FontSize="12"
                   Foreground="{StaticResource TextDisabledBrush}" />
      </StackPanel>

      <Button Content="Save"
              Command="{x:Bind ViewModel.SaveCommand}"
              HorizontalAlignment="Left" />

      <TextBlock Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                 TextWrapping="Wrap"
                 Foreground="{StaticResource AccentBrush}" />

      <StackPanel Spacing="8">
        <TextBlock Text="Manage Registered Folders"
                   Foreground="{StaticResource TextPrimaryBrush}" />
        <ListView x:Name="FolderList"
                  ItemsSource="{x:Bind ViewModel.Folders}"
                  SelectionChanged="OnFolderSelectionChanged"
                  SelectionMode="Single"
                  MaxHeight="220"
                  BorderBrush="{StaticResource BorderSubtleBrush}"
                  BorderThickness="1">
          <ListView.ItemTemplate>
            <DataTemplate x:DataType="models:Folder">
              <StackPanel Margin="0,4">
                <TextBlock Text="{x:Bind Name}"
                           Foreground="{StaticResource TextPrimaryBrush}" />
                <TextBlock Text="{x:Bind Path}"
                           FontSize="11"
                           Foreground="{StaticResource TextDisabledBrush}" />
              </StackPanel>
            </DataTemplate>
          </ListView.ItemTemplate>
        </ListView>
        <Button Content="Remove From Catalog..."
                Click="OnRemoveFolderClicked"
                IsEnabled="{x:Bind ViewModel.IsFolderSelected, Mode=OneWay}" />
        <TextBlock Text="Removes the folder's photos from the app's catalog. The image files themselves are not deleted."
                   FontSize="12"
                   Foreground="{StaticResource TextDisabledBrush}" />
      </StackPanel>

      <StackPanel Spacing="8">
        <TextBlock Text="Maintenance"
                   Foreground="{StaticResource TextPrimaryBrush}" />
        <Button Content="Clear Thumbnail Cache (Regenerate All)"
                Command="{x:Bind ViewModel.ClearThumbnailCacheCommand}" />
        <TextBlock Text="Deletes all thumbnails and rebuilds them. Use this to recover corrupted thumbnails."
                   FontSize="12"
                   Foreground="{StaticResource TextDisabledBrush}" />
      </StackPanel>
    </StackPanel>
  </ScrollViewer>
</Page>
