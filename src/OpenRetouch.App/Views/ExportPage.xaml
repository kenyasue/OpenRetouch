<Page
  x:Class="OpenRetouch.App.Views.ExportPage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:vm="using:OpenRetouch.App.ViewModels"
  Background="{StaticResource BackgroundPrimaryBrush}">

  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="420" />
      <ColumnDefinition Width="*" />
    </Grid.ColumnDefinitions>

    <!-- ============ Left: Settings Form ============ -->
    <ScrollViewer Grid.Column="0">
      <StackPanel Margin="24" Spacing="8">
        <TextBlock Text="Export"
                   FontSize="24"
                   Foreground="{StaticResource TextPrimaryBrush}" />
        <TextBlock Text="{x:Bind ViewModel.TargetSummary, Mode=OneWay}"
                   Foreground="{StaticResource AccentBrush}"
                   TextWrapping="Wrap" />

        <TextBlock Text="Export Preset" FontSize="12" Margin="0,8,0,0"
                   Foreground="{StaticResource TextDisabledBrush}" />
        <ComboBox ItemsSource="{x:Bind ViewModel.PresetNames}"
                  SelectedIndex="{x:Bind ViewModel.SelectedPresetIndex, Mode=TwoWay}"
                  HorizontalAlignment="Stretch" />

        <TextBlock Text="Output Folder" FontSize="12" Margin="0,8,0,0"
                   Foreground="{StaticResource TextDisabledBrush}" />
        <Grid ColumnSpacing="4">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>
          <TextBox Text="{x:Bind ViewModel.OutputFolder, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                   PlaceholderText="Select a folder..." />
          <Button Grid.Column="1" Content="Browse..." Command="{x:Bind ViewModel.PickOutputFolderCommand}" />
        </Grid>

        <TextBlock Text="Format" FontSize="12" Margin="0,8,0,0"
                   Foreground="{StaticResource TextDisabledBrush}" />
        <ComboBox SelectedIndex="{x:Bind ViewModel.FormatIndex, Mode=TwoWay}" HorizontalAlignment="Stretch">
          <ComboBoxItem Content="JPEG" />
          <ComboBoxItem Content="PNG" />
          <ComboBoxItem Content="TIFF" />
        </ComboBox>

        <StackPanel Visibility="{x:Bind ViewModel.IsJpegQualityVisible, Mode=OneWay}" Spacing="4">
          <TextBlock Text="JPEG Quality" FontSize="12" Foreground="{StaticResource TextDisabledBrush}" />
          <Grid ColumnSpacing="8">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" /><ColumnDefinition Width="72" />
            </Grid.ColumnDefinitions>
            <Slider Minimum="1" Maximum="100" StepFrequency="1"
                    Value="{x:Bind ViewModel.JpegQuality, Mode=TwoWay}" />
            <NumberBox Grid.Column="1" Minimum="1" Maximum="100"
                       Value="{x:Bind ViewModel.JpegQuality, Mode=TwoWay}" />
          </Grid>
        </StackPanel>

        <TextBlock Text="Resize" FontSize="12" Margin="0,8,0,0"
                   Foreground="{StaticResource TextDisabledBrush}" />
        <ComboBox SelectedIndex="{x:Bind ViewModel.ResizeModeIndex, Mode=TwoWay}" HorizontalAlignment="Stretch">
          <ComboBoxItem Content="No Resize" />
          <ComboBoxItem Content="Long Edge" />
          <ComboBoxItem Content="Short Edge" />
        </ComboBox>
        <NumberBox Visibility="{x:Bind ViewModel.IsResizeValueVisible, Mode=OneWay}"
                   Header="Size (px)"
                   Minimum="16" Maximum="20000" SmallChange="64"
                   Value="{x:Bind ViewModel.ResizeValue, Mode=TwoWay}"
                   HorizontalAlignment="Left" Width="200" />

        <TextBlock Text="File Name Template ({filename} {seq} {date})" FontSize="12" Margin="0,8,0,0"
                   Foreground="{StaticResource TextDisabledBrush}" />
        <TextBox Text="{x:Bind ViewModel.FileNameTemplateText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

        <TextBlock Text="If a File With the Same Name Exists" FontSize="12" Margin="0,8,0,0"
                   Foreground="{StaticResource TextDisabledBrush}" />
        <ComboBox SelectedIndex="{x:Bind ViewModel.ConflictPolicyIndex, Mode=TwoWay}" HorizontalAlignment="Stretch">
          <ComboBoxItem Content="Rename and save (name (2).jpg)" />
          <ComboBoxItem Content="Overwrite" />
          <ComboBoxItem Content="Skip" />
        </ComboBox>

        <CheckBox Content="Keep metadata (EXIF)"
                  IsChecked="{x:Bind ViewModel.KeepExif, Mode=TwoWay}"
                  Margin="0,8,0,0" />
        <CheckBox Content="Remove GPS data"
                  IsChecked="{x:Bind ViewModel.RemoveGps, Mode=TwoWay}"
                  IsEnabled="{x:Bind ViewModel.KeepExif, Mode=OneWay}" />

        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,16,0,0">
          <Button Content="Start Export"
                  Style="{ThemeResource AccentButtonStyle}"
                  Command="{x:Bind ViewModel.StartExportCommand}"
                  IsEnabled="{x:Bind ViewModel.IsNotExporting, Mode=OneWay}" />
          <Button Content="Cancel"
                  Command="{x:Bind ViewModel.CancelExportCommand}"
                  IsEnabled="{x:Bind ViewModel.IsExporting, Mode=OneWay}" />
        </StackPanel>
      </StackPanel>
    </ScrollViewer>

    <!-- ============ Right: Results ============ -->
    <Border Grid.Column="1"
            Background="{StaticResource BackgroundPanelBrush}"
            BorderBrush="{StaticResource BorderSubtleBrush}"
            BorderThickness="1,0,0,0">
      <StackPanel Margin="24" Spacing="8">
        <TextBlock Text="Results"
                   FontWeight="SemiBold"
                   Foreground="{StaticResource TextPrimaryBrush}" />
        <TextBlock Text="{x:Bind ViewModel.ResultSummary, Mode=OneWay}"
                   Foreground="{StaticResource TextPrimaryBrush}"
                   TextWrapping="Wrap" />
        <Button Content="Retry Failed Only"
                Command="{x:Bind ViewModel.RetryFailedCommand}"
                Visibility="{x:Bind ViewModel.HasFailedItems, Mode=OneWay}" />

        <TextBlock Text="Failed / Skipped Items" FontSize="12" Margin="0,8,0,0"
                   Foreground="{StaticResource TextDisabledBrush}" />
        <ListView ItemsSource="{x:Bind ViewModel.ResultItems}" MaxHeight="400" SelectionMode="None">
          <ListView.ItemTemplate>
            <DataTemplate x:DataType="vm:ExportResultItem">
              <StackPanel>
                <TextBlock Foreground="{StaticResource TextPrimaryBrush}">
                  <Run Text="{x:Bind FileName}" />
                  <Run Text=" - " />
                  <Run Text="{x:Bind Status}" />
                </TextBlock>
                <TextBlock Text="{x:Bind Detail}"
                           FontSize="11"
                           Foreground="{StaticResource FlagRejectBrush}"
                           TextWrapping="Wrap" />
              </StackPanel>
            </DataTemplate>
          </ListView.ItemTemplate>
        </ListView>
      </StackPanel>
    </Border>
  </Grid>
</Page>
