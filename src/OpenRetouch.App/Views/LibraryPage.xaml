<Page
  x:Class="OpenRetouch.App.Views.LibraryPage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:vm="using:OpenRetouch.App.ViewModels"
  xmlns:models="using:OpenRetouch.Core.Models"
  xmlns:conv="using:OpenRetouch.App.Converters"
  Background="{StaticResource BackgroundPrimaryBrush}">

  <Page.Resources>
    <conv:PathToImageSourceConverter x:Key="PathToImage" />
    <CollectionViewSource x:Name="GroupedPhotos"
                          IsSourceGrouped="True"
                          Source="{x:Bind ViewModel.PhotoGroups}" />
  </Page.Resources>

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="*" />
      <RowDefinition Height="110" />
    </Grid.RowDefinitions>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="230" />
      <ColumnDefinition Width="*" />
      <ColumnDefinition Width="300" />
    </Grid.ColumnDefinitions>

    <!-- ============ Left Panel ============ -->
    <Border Grid.Row="0" Grid.Column="0"
            Background="{StaticResource BackgroundPanelBrush}"
            BorderBrush="{StaticResource BorderSubtleBrush}"
            BorderThickness="0,0,1,0">
      <ScrollViewer>
        <StackPanel Margin="12" Spacing="6">

          <Button Content="All Photos"
                  HorizontalAlignment="Stretch"
                  Click="OnShowAllPhotos" />

          <!-- Folders -->
          <TextBlock Text="Folders" Foreground="{StaticResource TextDisabledBrush}" Margin="0,8,0,0" />
          <ListView ItemsSource="{x:Bind ViewModel.Folders}"
                    SelectedItem="{x:Bind ViewModel.SelectedFolder, Mode=TwoWay}"
                    SelectionMode="Single"
                    MaxHeight="160">
            <ListView.ItemTemplate>
              <DataTemplate x:DataType="models:Folder">
                <TextBlock Text="{x:Bind Name}" Foreground="{StaticResource TextPrimaryBrush}" />
              </DataTemplate>
            </ListView.ItemTemplate>
          </ListView>

          <!-- Albums -->
          <TextBlock Text="Albums" Foreground="{StaticResource TextDisabledBrush}" Margin="0,8,0,0" />
          <ListView ItemsSource="{x:Bind ViewModel.Albums}"
                    SelectedItem="{x:Bind ViewModel.SelectedAlbum, Mode=TwoWay}"
                    SelectionMode="Single"
                    MaxHeight="160">
            <ListView.ItemTemplate>
              <DataTemplate x:DataType="models:Album">
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                  </Grid.ColumnDefinitions>
                  <TextBlock Text="{x:Bind Name}"
                             Foreground="{StaticResource TextPrimaryBrush}"
                             VerticalAlignment="Center" />
                  <Button Grid.Column="1"
                          Content="&#xE74D;"
                          FontFamily="Segoe Fluent Icons"
                          FontSize="11"
                          Padding="4"
                          Background="Transparent"
                          BorderThickness="0"
                          Click="OnDeleteAlbum"
                          Tag="{x:Bind}" />
                </Grid>
              </DataTemplate>
            </ListView.ItemTemplate>
          </ListView>

          <Grid ColumnSpacing="4">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox PlaceholderText="New album name"
                     Text="{x:Bind ViewModel.NewAlbumName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            <Button Grid.Column="1" Content="+" Command="{x:Bind ViewModel.CreateAlbumCommand}" />
          </Grid>

          <!-- Filters -->
          <TextBlock Text="Filters" Foreground="{StaticResource TextDisabledBrush}" Margin="0,12,0,0" />

          <TextBlock Text="Rating (and up)" FontSize="12" Foreground="{StaticResource TextDisabledBrush}" />
          <ComboBox SelectedIndex="{x:Bind ViewModel.MinRatingFilter, Mode=TwoWay}" HorizontalAlignment="Stretch">
            <ComboBoxItem Content="All" />
            <ComboBoxItem Content="★1 and up" />
            <ComboBoxItem Content="★2 and up" />
            <ComboBoxItem Content="★3 and up" />
            <ComboBoxItem Content="★4 and up" />
            <ComboBoxItem Content="★5" />
          </ComboBox>

          <TextBlock Text="Flag" FontSize="12" Foreground="{StaticResource TextDisabledBrush}" />
          <ComboBox SelectedIndex="{x:Bind ViewModel.FlagFilterIndex, Mode=TwoWay}" HorizontalAlignment="Stretch">
            <ComboBoxItem Content="All" />
            <ComboBoxItem Content="Pick" />
            <ComboBoxItem Content="Reject" />
            <ComboBoxItem Content="Unflagged" />
          </ComboBox>

          <TextBlock Text="Color Label" FontSize="12" Foreground="{StaticResource TextDisabledBrush}" />
          <ComboBox SelectedIndex="{x:Bind ViewModel.ColorLabelFilterIndex, Mode=TwoWay}" HorizontalAlignment="Stretch">
            <ComboBoxItem Content="All" />
            <ComboBoxItem Content="Red" />
            <ComboBoxItem Content="Yellow" />
            <ComboBoxItem Content="Green" />
            <ComboBoxItem Content="Blue" />
            <ComboBoxItem Content="Purple" />
          </ComboBox>

          <TextBlock Text="File Format" FontSize="12" Foreground="{StaticResource TextDisabledBrush}" />
          <ComboBox SelectedIndex="{x:Bind ViewModel.ExtensionFilterIndex, Mode=TwoWay}" HorizontalAlignment="Stretch">
            <ComboBoxItem Content="All" />
            <ComboBoxItem Content="JPEG" />
            <ComboBoxItem Content="PNG" />
            <ComboBoxItem Content="TIFF" />
            <ComboBoxItem Content="RAW" />
          </ComboBox>

          <!-- Sort -->
          <TextBlock Text="Sort" Foreground="{StaticResource TextDisabledBrush}" Margin="0,12,0,0" />
          <ComboBox SelectedIndex="{x:Bind ViewModel.SortFieldIndex, Mode=TwoWay}" HorizontalAlignment="Stretch">
            <ComboBoxItem Content="Capture Date" />
            <ComboBoxItem Content="Import Date" />
            <ComboBoxItem Content="File Name" />
          </ComboBox>
          <ToggleSwitch Header=""
                        OnContent="Descending" OffContent="Ascending"
                        IsOn="{x:Bind ViewModel.SortDescending, Mode=TwoWay}" />

          <TextBlock Text="{x:Bind ViewModel.StatusText, Mode=OneWay}"
                     FontSize="12"
                     Foreground="{StaticResource AccentBrush}"
                     TextWrapping="Wrap"
                     Margin="0,8,0,0" />
        </StackPanel>
      </ScrollViewer>
    </Border>

    <!-- ============ Center: Grid / Single Photo Preview ============ -->
    <Grid Grid.Row="0" Grid.Column="1" Background="{StaticResource BackgroundCanvasBrush}">

      <Grid Visibility="{x:Bind ViewModel.IsGridVisible, Mode=OneWay}">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <!-- Batch edit toolbar (applies to selected photos) -->
        <Border Grid.Row="0" Grid.ColumnSpan="2"
                Background="{StaticResource BackgroundPanelBrush}"
                BorderBrush="{StaticResource BorderSubtleBrush}"
                BorderThickness="0,0,0,1">
          <StackPanel Orientation="Horizontal" Spacing="8" Padding="12,6">
            <Button Content="Auto Tone"
                    Command="{x:Bind ViewModel.AutoToneSelectionCommand}"
                    ToolTipService.ToolTip="Automatically correct the tone of the selected photos" />
            <DropDownButton Content="Apply Preset">
              <DropDownButton.Flyout>
                <MenuFlyout x:Name="PresetToolbarFlyout" Opening="OnPresetToolbarFlyoutOpening" />
              </DropDownButton.Flyout>
            </DropDownButton>
            <Button Content="Copy Settings"
                    Command="{x:Bind ViewModel.CopySettingsFromSelectionCommand}"
                    IsEnabled="{x:Bind ViewModel.HasSelection, Mode=OneWay}"
                    ToolTipService.ToolTip="Copy the edit settings of the selected photo (shared with the Edit page)" />
            <Button Content="Paste Settings"
                    Command="{x:Bind ViewModel.PasteSettingsToSelectionCommand}"
                    ToolTipService.ToolTip="Batch apply the copied edit settings to the selected photos" />
          </StackPanel>
        </Border>

        <GridView x:Name="PhotoGrid"
                  Grid.Row="1"
                  Grid.Column="0"
                  Margin="8"
                  ItemsSource="{x:Bind GroupedPhotos.View}"
                  SelectionMode="Extended"
                  SelectionChanged="OnGridSelectionChanged"
                  IsItemClickEnabled="False"
                  DoubleTapped="OnGridDoubleTapped"
                  Loaded="OnPhotoGridLoaded">
          <GridView.ContextFlyout>
            <MenuFlyout x:Name="GridContextMenu" Opening="OnGridContextMenuOpening" />
          </GridView.ContextFlyout>
          <GridView.GroupStyle>
            <GroupStyle HidesIfEmpty="True">
              <GroupStyle.HeaderTemplate>
                <DataTemplate x:DataType="vm:PhotoGroup">
                  <!-- Year/month title: large light-weight month + letter-spaced year + accent rule -->
                  <StackPanel Margin="6,18,0,6" Visibility="{x:Bind HasHeader}">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                      <TextBlock Text="{x:Bind MonthTitle}"
                                 FontSize="30"
                                 FontWeight="SemiLight"
                                 Foreground="{StaticResource TextPrimaryBrush}" />
                      <TextBlock Text="{x:Bind YearTitle}"
                                 FontSize="13"
                                 CharacterSpacing="240"
                                 Foreground="{StaticResource AccentBrush}"
                                 VerticalAlignment="Bottom"
                                 Margin="0,0,0,7" />
                    </StackPanel>
                    <Rectangle Height="1"
                               Width="72"
                               HorizontalAlignment="Left"
                               Margin="2,4,0,0"
                               Fill="{StaticResource AccentBrush}"
                               Opacity="0.5" />
                  </StackPanel>
                </DataTemplate>
              </GroupStyle.HeaderTemplate>
            </GroupStyle>
          </GridView.GroupStyle>
          <GridView.ItemTemplate>
            <DataTemplate x:DataType="vm:PhotoItemViewModel">
              <Grid Width="148" Height="148" Margin="2"
                    Background="{StaticResource BackgroundPanelBrush}"
                    BorderBrush="{x:Bind ColorLabelBrush, Mode=OneWay}"
                    BorderThickness="2">
                <Grid.RowDefinitions>
                  <RowDefinition Height="*" />
                  <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <FontIcon Grid.Row="0"
                          Glyph="&#xE91B;"
                          FontSize="28"
                          Foreground="{StaticResource TextDisabledBrush}" />
                <Image Grid.Row="0"
                       Source="{x:Bind ThumbnailPath, Mode=OneWay, Converter={StaticResource PathToImage}}"
                       Stretch="Uniform"
                       Margin="4" />
                <!-- Flag overlay -->
                <FontIcon Grid.Row="0"
                          Glyph="&#xE73E;"
                          FontSize="14"
                          Foreground="{StaticResource FlagPickBrush}"
                          HorizontalAlignment="Left" VerticalAlignment="Top"
                          Margin="6"
                          Visibility="{x:Bind IsPicked, Mode=OneWay}" />
                <FontIcon Grid.Row="0"
                          Glyph="&#xE711;"
                          FontSize="14"
                          Foreground="{StaticResource FlagRejectBrush}"
                          HorizontalAlignment="Left" VerticalAlignment="Top"
                          Margin="6"
                          Visibility="{x:Bind IsRejected, Mode=OneWay}" />
                <!-- Rating overlay -->
                <TextBlock Grid.Row="0"
                           Text="{x:Bind RatingStars, Mode=OneWay}"
                           FontSize="12"
                           Foreground="{StaticResource RatingStarBrush}"
                           HorizontalAlignment="Right" VerticalAlignment="Bottom"
                           Margin="6,0" />
                <TextBlock Grid.Row="1"
                           Text="{x:Bind FileName}"
                           FontSize="11"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           TextTrimming="CharacterEllipsis"
                           HorizontalAlignment="Center"
                           Margin="4,0,4,4" />
              </Grid>
            </DataTemplate>
          </GridView.ItemTemplate>
        </GridView>

        <!-- Timeline bar (year/month navigation; shown only when sorted by capture date) -->
        <Border Grid.Row="1" Grid.Column="1"
                Width="52"
                Visibility="{x:Bind ViewModel.IsTimelineVisible, Mode=OneWay}"
                Background="{StaticResource BackgroundPanelBrush}"
                BorderBrush="{StaticResource BorderSubtleBrush}"
                BorderThickness="1,0,0,0">
          <ScrollViewer VerticalScrollBarVisibility="Hidden">
            <ItemsControl ItemsSource="{x:Bind ViewModel.TimelineEntries}" Margin="0,4,0,12">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:TimelineEntryViewModel">
                  <StackPanel>
                    <TextBlock Text="{x:Bind YearLabel}"
                               FontSize="11"
                               FontWeight="SemiBold"
                               CharacterSpacing="120"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,10,0,2"
                               Visibility="{x:Bind HasYearLabel}" />
                    <Button Content="{x:Bind MonthLabel}"
                            Foreground="{x:Bind MonthBrush, Mode=OneWay}"
                            FontSize="12"
                            Background="Transparent"
                            BorderThickness="0"
                            Padding="0,2"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"
                            Click="OnTimelineMonthClicked"
                            Tag="{x:Bind}" />
                  </StackPanel>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
        </Border>

        <StackPanel Grid.Row="1" Grid.ColumnSpan="2" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8"
                    Visibility="{x:Bind ViewModel.IsEmptyStateVisible, Mode=OneWay}">
          <TextBlock Text="No Photos"
                     FontSize="20"
                     Foreground="{StaticResource TextPrimaryBrush}"
                     HorizontalAlignment="Center" />
          <TextBlock Text="Use &quot;Import&quot; in the top bar to import a folder"
                     Foreground="{StaticResource TextDisabledBrush}"
                     HorizontalAlignment="Center" />
        </StackPanel>
      </Grid>

      <Grid Visibility="{x:Bind ViewModel.IsSinglePhotoView, Mode=OneWay}"
            Background="{StaticResource BackgroundCanvasBrush}">
        <Image Source="{x:Bind ViewModel.SelectedPhoto.FilePath, Mode=OneWay, Converter={StaticResource PathToImage}}"
               Stretch="Uniform"
               Margin="16" />
        <Button Content="Back (Esc)"
                Command="{x:Bind ViewModel.ExitSinglePhotoViewCommand}"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Margin="12" />
      </Grid>
    </Grid>

    <!-- ============ Right Panel: Metadata + Culling ============ -->
    <Border Grid.Row="0" Grid.Column="2"
            Background="{StaticResource BackgroundPanelBrush}"
            BorderBrush="{StaticResource BorderSubtleBrush}"
            BorderThickness="1,0,0,0">
      <ScrollViewer>
        <StackPanel Margin="16" Spacing="4"
                    Visibility="{x:Bind ViewModel.HasSelection, Mode=OneWay}">

          <!-- Culling actions -->
          <TextBlock Text="Culling" FontWeight="SemiBold"
                     Foreground="{StaticResource TextPrimaryBrush}" />
          <RatingControl x:Name="RatingInput"
                         MaxRating="5"
                         IsClearEnabled="True"
                         Value="{x:Bind ViewModel.SelectedPhoto.Rating, Mode=OneWay}"
                         ValueChanged="OnRatingControlChanged"
                         HorizontalAlignment="Left" />
          <StackPanel Orientation="Horizontal" Spacing="4">
            <Button Content="Pick (P)" Command="{x:Bind ViewModel.SetPickFlagCommand}" />
            <Button Content="Reject (X)" Command="{x:Bind ViewModel.SetRejectFlagCommand}" />
            <Button Content="Clear (U)" Command="{x:Bind ViewModel.ClearFlagCommand}" />
          </StackPanel>
          <StackPanel Orientation="Horizontal" Spacing="4">
            <Button Background="{StaticResource LabelRedBrush}" Width="28" Height="20" Padding="0" Click="OnLabelRed" />
            <Button Background="{StaticResource LabelYellowBrush}" Width="28" Height="20" Padding="0" Click="OnLabelYellow" />
            <Button Background="{StaticResource LabelGreenBrush}" Width="28" Height="20" Padding="0" Click="OnLabelGreen" />
            <Button Background="{StaticResource LabelBlueBrush}" Width="28" Height="20" Padding="0" Click="OnLabelBlue" />
            <Button Background="{StaticResource LabelPurpleBrush}" Width="28" Height="20" Padding="0" Click="OnLabelPurple" />
            <Button Content="None" FontSize="11" Padding="6,2" Click="OnLabelNone" />
          </StackPanel>

          <!-- Metadata -->
          <TextBlock Text="Metadata"
                     FontWeight="SemiBold"
                     Foreground="{StaticResource TextPrimaryBrush}"
                     Margin="0,16,0,8" />
          <TextBlock Text="{x:Bind ViewModel.SelectedPhoto.FileName, Mode=OneWay}"
                     Foreground="{StaticResource TextPrimaryBrush}"
                     TextWrapping="Wrap" />
          <TextBlock Text="{x:Bind ViewModel.SelectedPhoto.FilePath, Mode=OneWay}"
                     FontSize="11"
                     Foreground="{StaticResource TextDisabledBrush}"
                     TextWrapping="Wrap"
                     Margin="0,0,0,8" />

          <Grid ColumnSpacing="8" RowSpacing="4">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
              <RowDefinition /> <RowDefinition /> <RowDefinition /> <RowDefinition />
              <RowDefinition /> <RowDefinition /> <RowDefinition /> <RowDefinition />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Size" Foreground="{StaticResource TextDisabledBrush}" />
            <TextBlock Grid.Row="0" Grid.Column="1" Foreground="{StaticResource TextPrimaryBrush}"
                       Text="{x:Bind ViewModel.SelectedPhoto.FileSizeText, Mode=OneWay}" />
            <TextBlock Grid.Row="1" Text="Dimensions" Foreground="{StaticResource TextDisabledBrush}" />
            <TextBlock Grid.Row="1" Grid.Column="1" Foreground="{StaticResource TextPrimaryBrush}"
                       Text="{x:Bind ViewModel.SelectedPhoto.DimensionsText, Mode=OneWay}" />
            <TextBlock Grid.Row="2" Text="Capture Date" Foreground="{StaticResource TextDisabledBrush}" />
            <TextBlock Grid.Row="2" Grid.Column="1" Foreground="{StaticResource TextPrimaryBrush}"
                       Text="{x:Bind ViewModel.SelectedPhoto.CapturedAtText, Mode=OneWay}" />
            <TextBlock Grid.Row="3" Text="Camera" Foreground="{StaticResource TextDisabledBrush}" />
            <TextBlock Grid.Row="3" Grid.Column="1" Foreground="{StaticResource TextPrimaryBrush}"
                       Text="{x:Bind ViewModel.SelectedPhoto.CameraText, Mode=OneWay}" TextWrapping="Wrap" />
            <TextBlock Grid.Row="4" Text="Lens" Foreground="{StaticResource TextDisabledBrush}" />
            <TextBlock Grid.Row="4" Grid.Column="1" Foreground="{StaticResource TextPrimaryBrush}"
                       Text="{x:Bind ViewModel.SelectedPhoto.LensText, Mode=OneWay}" TextWrapping="Wrap" />
            <TextBlock Grid.Row="5" Text="ISO" Foreground="{StaticResource TextDisabledBrush}" />
            <TextBlock Grid.Row="5" Grid.Column="1" Foreground="{StaticResource TextPrimaryBrush}"
                       Text="{x:Bind ViewModel.SelectedPhoto.IsoText, Mode=OneWay}" />
            <TextBlock Grid.Row="6" Text="Aperture / SS" Foreground="{StaticResource TextDisabledBrush}" />
            <TextBlock Grid.Row="6" Grid.Column="1" Foreground="{StaticResource TextPrimaryBrush}">
              <Run Text="{x:Bind ViewModel.SelectedPhoto.ApertureText, Mode=OneWay}" />
              <Run Text=" / " />
              <Run Text="{x:Bind ViewModel.SelectedPhoto.ShutterSpeedText, Mode=OneWay}" />
            </TextBlock>
            <TextBlock Grid.Row="7" Text="Focal Length" Foreground="{StaticResource TextDisabledBrush}" />
            <TextBlock Grid.Row="7" Grid.Column="1" Foreground="{StaticResource TextPrimaryBrush}"
                       Text="{x:Bind ViewModel.SelectedPhoto.FocalLengthText, Mode=OneWay}" />
          </Grid>
        </StackPanel>
      </ScrollViewer>
    </Border>

    <!-- ============ Filmstrip ============ -->
    <Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3"
            Background="{StaticResource BackgroundPanelBrush}"
            BorderBrush="{StaticResource BorderSubtleBrush}"
            BorderThickness="0,1,0,0">
      <ListView ItemsSource="{x:Bind ViewModel.Photos}"
                SelectedItem="{x:Bind ViewModel.SelectedPhoto, Mode=TwoWay}"
                SelectionMode="Single"
                ScrollViewer.HorizontalScrollBarVisibility="Auto"
                ScrollViewer.HorizontalScrollMode="Enabled"
                ScrollViewer.VerticalScrollMode="Disabled"
                Padding="4">
        <ListView.ItemsPanel>
          <ItemsPanelTemplate>
            <ItemsStackPanel Orientation="Horizontal" />
          </ItemsPanelTemplate>
        </ListView.ItemsPanel>
        <ListView.ItemTemplate>
          <DataTemplate x:DataType="vm:PhotoItemViewModel">
            <Grid Width="84" Height="84" Background="{StaticResource BackgroundCanvasBrush}">
              <FontIcon Glyph="&#xE91B;" FontSize="16" Foreground="{StaticResource TextDisabledBrush}" />
              <Image Source="{x:Bind ThumbnailPath, Mode=OneWay, Converter={StaticResource PathToImage}}"
                     Stretch="Uniform" Margin="2" />
            </Grid>
          </DataTemplate>
        </ListView.ItemTemplate>
      </ListView>
    </Border>
  </Grid>

  <Page.KeyboardAccelerators>
    <KeyboardAccelerator Key="Escape" Invoked="OnEscapeInvoked" />
    <KeyboardAccelerator Key="Number0" Invoked="OnRatingKeyInvoked" />
    <KeyboardAccelerator Key="Number1" Invoked="OnRatingKeyInvoked" />
    <KeyboardAccelerator Key="Number2" Invoked="OnRatingKeyInvoked" />
    <KeyboardAccelerator Key="Number3" Invoked="OnRatingKeyInvoked" />
    <KeyboardAccelerator Key="Number4" Invoked="OnRatingKeyInvoked" />
    <KeyboardAccelerator Key="Number5" Invoked="OnRatingKeyInvoked" />
    <KeyboardAccelerator Key="Number6" Invoked="OnLabelKeyInvoked" />
    <KeyboardAccelerator Key="Number7" Invoked="OnLabelKeyInvoked" />
    <KeyboardAccelerator Key="Number8" Invoked="OnLabelKeyInvoked" />
    <KeyboardAccelerator Key="Number9" Invoked="OnLabelKeyInvoked" />
    <KeyboardAccelerator Key="P" Invoked="OnFlagKeyInvoked" />
    <KeyboardAccelerator Key="X" Invoked="OnFlagKeyInvoked" />
    <KeyboardAccelerator Key="U" Invoked="OnFlagKeyInvoked" />
    <KeyboardAccelerator Key="D" Invoked="OnEditKeyInvoked" />
    <KeyboardAccelerator Key="Enter" Invoked="OnEnterKeyInvoked" />
  </Page.KeyboardAccelerators>
</Page>
