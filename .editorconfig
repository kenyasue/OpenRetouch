root = true

[*]
charset = utf-8
end_of_line = crlf
insert_final_newline = true
indent_style = space
trim_trailing_whitespace = true

[*.{json,yml,yaml,xml,xaml,csproj,props,targets,sln}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[*.sql]
indent_size = 4

[*.cs]
indent_size = 4
max_line_length = 120

# --- C# style ---
csharp_style_namespace_declarations = file_scoped:warning
csharp_style_var_when_type_is_apparent = true:suggestion
csharp_style_var_elsewhere = false:suggestion
csharp_prefer_braces = true:suggestion
csharp_style_prefer_primary_constructors = false:suggestion
csharp_using_directive_placement = outside_namespace:warning

# --- Naming: private static fields PascalCase (先に評価される) ---
dotnet_naming_rule.private_static_fields_pascal.severity = warning
dotnet_naming_rule.private_static_fields_pascal.symbols = private_static_fields
dotnet_naming_rule.private_static_fields_pascal.style = pascal_case_style

dotnet_naming_symbols.private_static_fields.applicable_kinds = field
dotnet_naming_symbols.private_static_fields.applicable_accessibilities = private
dotnet_naming_symbols.private_static_fields.required_modifiers = static

dotnet_naming_style.pascal_case_style.capitalization = pascal_case

# --- Naming: private instance fields _camelCase ---
dotnet_naming_rule.private_fields_underscore.severity = warning
dotnet_naming_rule.private_fields_underscore.symbols = private_fields
dotnet_naming_rule.private_fields_underscore.style = underscore_camel_case

dotnet_naming_symbols.private_fields.applicable_kinds = field
dotnet_naming_symbols.private_fields.applicable_accessibilities = private

dotnet_naming_style.underscore_camel_case.required_prefix = _
dotnet_naming_style.underscore_camel_case.capitalization = camel_case

# --- Analyzer severities ---
dotnet_diagnostic.CA2007.severity = none
dotnet_style_qualification_for_field = false:suggestion
dotnet_style_require_accessibility_modifiers = for_non_interface_members:warning
dotnet_sort_system_directives_first = true
